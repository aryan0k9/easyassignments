# =====================================
# SUPABASE CONFIGURATION
# =====================================
# This is a TEMPLATE file (safe to commit to git)
# Copy this to .env and fill in your real values
# Get these from: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# =====================================
# IMPORTANT NOTES
# =====================================
# - Never commit .env to git (only .env.example is safe)
# - The "anon" key is safe for browser use
# - NEVER use service_role key in frontend code
# - Restart your dev server after changing .env
