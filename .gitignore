# =====================================
# .gitignore - Files NOT to commit to GitHub
# =====================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Production builds
/dist
/build
.cache/

# Environment files (CRITICAL - contains secrets!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS files
Thumbs.db
desktop.ini

# Testing
/coverage
.nyc_output/

# Vite
.vite/
*.local

# Credentials (never commit!)
credentials*.txt
*.pem
*.key
